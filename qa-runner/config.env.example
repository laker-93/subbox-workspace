# Copy to config.env and fill in. config.env is gitignored (holds no secrets, but
# is machine-specific). The Discord *token* lives separately in
# ../discord-credentials.env and is sourced automatically.
#
# Tunables use `: "${VAR:=default}"` so an env override wins, e.g.
#   QA_CYCLES=1 ./run-daily.sh   (supervised single-cycle test)

# Private channel the runner posts digests to and reads your replies from.
# Create it once with:  ./setup-channel.sh   (prints the id to paste here). Required.
QA_DISCORD_CHANNEL_ID=

# How many continuous-ux cycles to run per daily batch. Each cycle is a fresh
# `claude -p` invocation (matching the loop's "fresh context per cycle" design).
: "${QA_CYCLES:=6}"

# Model + effort for each cycle.
: "${QA_MODEL:=claude-opus-4-8}"

# Optional hard cap per cycle (seconds) if `gtimeout` (coreutils) is installed;
# ignored otherwise. A docker rebuild + electron drive can be slow — leave headroom.
: "${QA_CYCLE_TIMEOUT:=2400}"

# PR flow: base branch each fix PR targets, and the label put on every auto PR.
# Defaults match the repos; override only if the base branches change.
: "${QA_FEISHIN_BASE:=development}"
: "${QA_PYMIX_BASE:=main}"
: "${QA_PR_LABEL:=qa-auto}"
